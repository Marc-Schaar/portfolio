{
  "permissions": {
    "allow": [
      "Bash(npx ng *)",
      "Skill(run)",
      "Skill(run:*)",
      "Bash(echo \"started with pid $!\")",
      "Bash(timeout 30 bash -c 'until curl -sf http://localhost:4300 >/dev/null; do sleep 1; done')",
      "Bash(chromium-cli --session portfolio)",
      "Bash(node -e \"require.resolve\\('playwright'\\)\")",
      "Bash(npx --yes playwright --version)",
      "Bash(npx --yes playwright install chromium --with-deps)",
      "Bash(npm init *)",
      "Bash(npm install *)",
      "Bash(node check.js)",
      "Bash(powershell -Command 'Get-NetTCPConnection -LocalPort 4300 -State Listen | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }')"
    ]
  }
}
